{
  "name": "your_video_is_mine",
  "description": "Your Video Is Mine — extension phát hiện và tải video (HLS/DASH/progressive)",
  "private": true,
  "version": "0.4.1",
  "packageManager": "pnpm@11.11.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/copy-ffmpeg-core.mjs && wxt",
    "dev:firefox": "node scripts/copy-ffmpeg-core.mjs && wxt -b firefox",
    "build": "node scripts/copy-ffmpeg-core.mjs && wxt build",
    "build:firefox": "node scripts/copy-ffmpeg-core.mjs && wxt build -b firefox",
    "zip": "node scripts/copy-ffmpeg-core.mjs && wxt zip",
    "zip:firefox": "node scripts/copy-ffmpeg-core.mjs && wxt zip -b firefox",
    "copy:ffmpeg": "node scripts/copy-ffmpeg-core.mjs",
    "compile": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "node scripts/copy-ffmpeg-core.mjs && wxt prepare"
  },
  "dependencies": {
    "@ffmpeg/core": "^0.12.10",
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "m3u8-parser": "^7.2.0",
    "mpd-parser": "^1.4.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@wxt-dev/module-react": "^1.1.5",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "prettier": "^3.9.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10",
    "wxt": "^0.20.27"
  }
}
